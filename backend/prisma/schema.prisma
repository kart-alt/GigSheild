generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Worker {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String?
  upiId     String?
  tier      Int      @default(3)
  createdAt DateTime @default(now())
}

model Claim {
  id        String   @id @default(uuid())
  workerId  String
  type      String
  amount    Float
  date      DateTime @default(now())
}
